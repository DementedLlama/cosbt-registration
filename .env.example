# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://cosbt:cosbt@localhost:5432/cosbt_camp"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Field-level Encryption (passport numbers) ────────────────────────────────
# Generate with: node -e "const {randomBytes}=require('crypto');console.log(randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# ─── AWS (leave empty for local dev; configure for staging/production) ─────────
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_SES_FROM_EMAIL=""
